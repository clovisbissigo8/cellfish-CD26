    )

------------

CREATE TABLE TB_CF_TIPO_LOGRADOURO 
    (
     id_tipo_logradouro INTEGER NOT NULL IDENTITY(1,1)
        CONSTRAINT PK_TIPO_LOGRADOURO PRIMARY KEY (id_tipo_logradouro), 
     tp_logradouro VARCHAR (20) NOT NULL
        CONSTRAINT UN_TIPO_LOGRADOURO_TP_LOGRADOURO UNIQUE(tp_logradouro)
    )

------------

CREATE TABLE TB_CF_PEIXE 
    (
     id_peixe INTEGER NOT NULL IDENTITY(1,1)
        CONSTRAINT PK_PEIXE PRIMARY KEY (id_peixe), 
